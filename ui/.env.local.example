# Copy this file to .env.local and fill in the values.
#
# After running `make dev`, register an account at http://localhost:3001/login,
# then log in and copy the token from localStorage (key: rustlings_token) here.
# This is only needed as a fallback for server-side rendering - the app works
# without it for normal browser usage.
NEXT_PUBLIC_API_TOKEN=

# Override the Rust API base URL used by Next.js rewrites.
# Defaults to http://localhost:3000 (standard local dev setup).
# Only needed if your local Rust API runs on a different port.
# API_BASE_URL=http://localhost:3000
